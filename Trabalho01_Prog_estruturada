#include <stdio.h>
#include <locale.h>
int main(){
    setlocale(LC_ALL, "Portuguese");
    // iremos usar essas variaveis para guardar os numeros e os resultados
    int num1, num2, num3;
    int soma, subtracao, multiplicacao;
    float divisao;

    // aqui iremos pedir o usuario para digitar os numeros
    printf("Digite um numero inteiro:");
    scanf("%d", &num1);
    printf("Digite outro numero inteiro:");
    scanf("%d", &num2);
    printf("digite mais um numero inteiro:");
    scanf("%d", &num3);

    //agora iremos realzar as operacoes
    soma = num1 + num2 + num3;
    subtracao = num1 - num2 - num3;
    multiplicacao = num1 * num2 * num3;
    divisao = (float)num1 / num2 / num3;

    // agora iremos mostrar os resultados das contas
    printf("A soma dos numeros e: %d\n", soma);
    printf("A subtracao dos numeros e: %d\n", subtracao);
    printf("A multiplicacao dos numeros e: %d\n", multiplicacao);
    printf("A divisao dos numeros e: %f\n", divisao);

    // agora que temos as contas feitas iremos fazer a verificaçao logica e relacional

    printf("________________Verificacao relacional________________ \n");
    if (num1 > num2){
        printf ("%d e maior que %d \n", num1, num2 );
    }
    else{
        printf("%d nao e maior que %d \n", num1, num2);
    }
    if (num2 > num3){
        printf ("%d e maior que %d \n", num2, num3 );
    }
    else{
        printf("%d nao e maior que %d \n", num2, num3);
    }

    // agora vamos para a verificacao logica
    printf("________________Verificacao logica________________ \n");
    if ( ( num1 > 0) && (num2 % 2 == 0) ) {
        printf("As duas condicoes foram verdadeiras \n");
    }
    else {
        printf("Somente uma das condicoes foi verdadeira \n");
    }

    return 0;
}
